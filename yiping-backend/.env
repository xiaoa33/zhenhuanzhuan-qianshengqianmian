# 是否使用 mock 数据（true = mock，false = 调用真实外部模块）
# 可用 USE_MOCK_LLM / USE_MOCK_TTS 覆盖单个模块
USE_MOCK=true
USE_MOCK_TTS=false
USE_MOCK_LLM=false

# 外部模块A：LLM文字生成 + 情绪分析（xiao-asr_llm）
LLM_SERVICE_URL=http://localhost:8001

# 外部模块B：TTS语音合成
TTS_SERVICE_URL=http://localhost:8002
GPT_SOVITS_SERVICE_URL=http://localhost:8004
COSYVOICE_SERVICE_URL=http://localhost:8002

# SadTalker 仓库路径（数字人功能必填，USE_MOCK=true 时也会调用 SadTalker）
# 克隆方式: git clone https://github.com/OpenTalker/SadTalker.git
SADTALKER_PATH=../SadTalker/SadTalker
SADTALKER_PYTHON=../SadTalker/SadTalker/.venv/Scripts/python.exe

# 对外暴露的静态资源基础 URL（用于生成 audio_url / video_url 返回给前端）
STATIC_BASE_URL=http://localhost:8003
#CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGINS=*

# 后端监听端口
PORT=8003
