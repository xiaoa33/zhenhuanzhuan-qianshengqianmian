# 是否使用 mock 数据（true = mock，false = 调用真实外部模块）
USE_MOCK=true

# 外部模块A：LLM文字生成 + 情绪分析（xiao-asr_llm）
LLM_SERVICE_URL=http://localhost:8001

# 外部模块B：TTS语音合成
TTS_SERVICE_URL=http://localhost:8002

# SadTalker 仓库路径（数字人功能必填，USE_MOCK=true 时也会调用 SadTalker）
# 克隆方式: git clone https://github.com/OpenTalker/SadTalker.git
SADTALKER_PATH=..\SadTalker
SADTALKER_PYTHON=..\SadTalker\.venv\Scripts\python.exe

# 对外暴露的静态资源基础 URL（用于生成 audio_url / video_url 返回给前端）
STATIC_BASE_URL=http://localhost:8000

# 后端监听端口
PORT=8000
